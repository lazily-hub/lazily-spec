    { "op": { "type": "push", "now": 10, "value": 5 }, "returns": 3, "expected": { "output": 3, "invalidates": { "output": true } } },
    { "op": { "type": "flush", "now": 20 }, "returns": 5, "expected": { "output": 5, "invalidates": { "output": true } } },
    { "op": { "type": "push", "now": 21, "value": 7 }, "returns": null, "expected": { "output": 5, "invalidates": { "output": false } } },
    { "op": { "type": "flush", "now": 30 }, "returns": 7, "expected": { "output": 7, "invalidates": { "output": true } } }
